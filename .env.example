# ── Copy this file to .env and fill in your values ──

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Reminder Times (24-hr format, Dhaka timezone)
SHOKAL_TIME=08:00
DUPUR_TIME=14:00
RATER_TIME=21:00

# Flask
SECRET_KEY=change-this-to-a-random-string
DASHBOARD_PASSWORD=your-password-here
PORT=5000

# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_VERIFY_TOKEN=any_random_secret_string
